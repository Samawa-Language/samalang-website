---
// Version Selector — adds a dropdown to the existing header
import DefaultHeader from '@astrojs/starlight/components/Header.astro';
---

<div class="version-selector-wrapper">
  <DefaultHeader {...Astro.props} />
  <div class="version-selector">
    <label for="version-select">v</label>
    <select id="version-select">
      <option value="/" selected>2.1 (latest)</option>
      <option value="/v1.0/">1.0</option>
      <option value="/v2.0/">2.0</option>
    </select>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const select = document.getElementById('version-select') as HTMLSelectElement;
    if (!select) return;

    const path = window.location.pathname;
    if (path.startsWith('/v1.0')) select.value = '/v1.0/';
    else if (path.startsWith('/v2.0')) select.value = '/v2.0/';
    else select.value = '/';

    select.addEventListener('change', () => {
      const val = select.value;
      const base = window.location.origin;
      window.location.href = base + val;
    });
  });
</script>

<style>
  .version-selector-wrapper {
    display: contents;
  }
  .version-selector {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.75rem;
    border-left: 1px solid var(--sl-color-gray-5);
    height: 100%;
  }
  .version-selector label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
  }
  .version-selector select {
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    line-height: 1;
  }
  .version-selector select:hover {
    border-color: var(--sl-color-accent);
  }
  .version-selector select:focus {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: -2px;
  }
</style>
